# =========================
# Flask application config
# =========================

# Generate a random string (do NOT commit the real one)
SECRET_KEY=change_me_in_local_env_only

# Debug and demo flags
DEBUG=true          # true for local development, false in production
DEMO_MODE=true      # true to allow demo auto-users, false in production

# =========================
# LLM configuration
# =========================

# Online vs local model
LLM_MODE=online     # "online" or "local"

# If using an OpenAI-compatible API
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL_NAME=gpt-4o-mini   # or any deployed OpenAI-compatible model

# If using Ollama locally (Phase 1: we read model name from Config)
# For local mode, set:
# LLM_MODE=local
# and then:
# LLM_MODEL_NAME=llama3.2

# =========================
# Database / misc
# =========================

# Path to SQLite DB (your code currently uses chatbot.db in project root)
DATABASE_PATH=chatbot.db
