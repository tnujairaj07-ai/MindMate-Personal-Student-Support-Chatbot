# Online LLM (OpenAI-compatible) – keep but unused when LLM_MODE=local
OPENAI_API_KEY=your_real_api_key_here

# LLM configuration
LLM_MODE=local              # "local" or "online"
LLM_MODEL_NAME=llama3.2     # or whatever you have in Ollama

# Flask / app
SECRET_KEY=some-super-random-string
DEBUG=true                  # dev only
DEMO_MODE=true              # dev only