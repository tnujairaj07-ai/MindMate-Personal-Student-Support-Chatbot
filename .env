# Online LLM (OpenAI-compatible)
OPENAI_API_KEY=your_real_api_key_here

# Which mode to use for LLM
LLM_MODE=online

# Default model name (for OpenAI this could be gpt-4o-mini or similar)
LLM_MODEL_NAME=gpt-4o-mini

# Flask / app
SECRET_KEY=your-very-long-random-secret-here
DEBUG=true
DEMO_MODE=true
